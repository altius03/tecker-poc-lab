# This PoC runs offline by default and does not require API keys.

EDR_CUSTOMER_ID=demo-customer
EDR_DEVICE_ID=kim-minjun-finance-laptop
EDR_AGENT_VERSION=0.1.0

# Optional telemetry shipping target.
EDR_SHIP_URL=https://collector.example.local/v1/telemetry:ingest

# Optional mTLS client certificate paths. Do not commit generated certs/private keys.
EDR_CLIENT_CERT=certs/device.crt
EDR_CLIENT_KEY=certs/device.key
